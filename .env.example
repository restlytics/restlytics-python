# restlytics Python SDK — example configuration.
# Copy to .env and fill in your key. The SDK reads these at restlytics.init().

# Required — your project's ingest key (sent as X-Restlytics-Key). Empty ⇒ inert.
RESTLYTICS_KEY=

# Where to send traces. The SDK POSTs to {INGEST_URL}/v1/traces.
RESTLYTICS_INGEST_URL=https://ingest.restlytics.com

# Resource attributes.
RESTLYTICS_SERVICE_NAME=my-api
RESTLYTICS_ENV=production

# Head-based sampling, 0.0–1.0 (decided once per trace).
RESTLYTICS_SAMPLE_RATE=1.0

# Transport: http (default) | null | log.
RESTLYTICS_TRANSPORT=http

# Capture raw SQL text (db.query.text). OFF by default — only the normalized,
# literal-free db.query.summary is sent regardless. Bindings are never sent.
RESTLYTICS_CAPTURE_SQL=false

# Optional tuning.
# RESTLYTICS_TIMEOUT_MS=2000
# RESTLYTICS_MAX_SPANS=2000
# RESTLYTICS_IGNORE_PATHS=/health,/healthz,/metrics
# RESTLYTICS_INSTRUMENT_DB=true
# RESTLYTICS_INSTRUMENT_HTTP=true
# RESTLYTICS_INSTRUMENT_CACHE=true
